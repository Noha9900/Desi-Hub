# ── Telegram ──────────────────────────────────────────────────────────────
BOT_TOKEN=                          # from @BotFather
BOT_MODE=webhook                    # webhook (recommended on Render/Koyeb/Heroku) | polling (VPS only)
PUBLIC_URL=                         # e.g. https://desihub-bot.onrender.com  (required if BOT_MODE=webhook)
WEBHOOK_SECRET_PATH=change-me-long-random-string   # random string used as part of the Telegram webhook URL path

ADMIN_TELEGRAM_ID=                  # your personal numeric Telegram user ID — get it from @userinfobot
VIP_CHANNELS=                       # JSON array, e.g. [{"name":"Desi Hub VIP 1","chatId":"-1001234567890"}]

# ── Mongo (MongoDB Atlas free tier) ─────────────────────────────────────────
MONGODB_URI=                        # mongodb+srv://user:pass@cluster.mongodb.net/desihub

# ── WordPress bridge ─────────────────────────────────────────────────────
WP_BASE_URL=https://yourdomain.com
WP_BRIDGE_SECRET=change-me-long-random-string   # MUST match "Bot Shared Secret" in Desi Hub -> Settings -> Telegram Bot

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
